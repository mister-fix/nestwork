{
	"$schema": "https://turborepo.com/schema.json",
	"ui": "tui",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	},
	"globalEnv": [
		"NEXT_PUBLIC_WEB_URL",
		"NEXT_PUBLIC_DOCS_URL",
		"DATABASE_URL",
		"RESEND_API_KEY",
		"BETTER_AUTH_URL",
		"BETTER_AUTH_SECRET"
	]
}
